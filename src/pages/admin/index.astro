---
/**
 * Admin Dashboard
 *
 * Clean Code: data fetching at page level (Astro),
 * each stat card is its own section. No React needed.
 */

import AdminLayout from "../../layouts/AdminLayout.astro";
import { pages, media, user, formSubmissions, activityLog } from "@/db/schema";
import { desc, eq, sql } from "drizzle-orm";

export const prerender = false;

const db = Astro.locals.db;

// Fetch stats in parallel
const [pageCount, mediaCount, userCount, formCount, recentActivity] =
  await Promise.all([
    db
      .select({ count: sql<number>`count(*)` })
      .from(pages)
      .then((r) => r[0]?.count ?? 0),
    db
      .select({ count: sql<number>`count(*)` })
      .from(media)
      .then((r) => r[0]?.count ?? 0),
    db
      .select({ count: sql<number>`count(*)` })
      .from(user)
      .then((r) => r[0]?.count ?? 0),
    db
      .select({ count: sql<number>`count(*)` })
      .from(formSubmissions)
      .then((r) => r[0]?.count ?? 0),
    db
      .select({
        id: activityLog.id,
        action: activityLog.action,
        entityType: activityLog.entityType,
        entityId: activityLog.entityId,
        metadata: activityLog.metadata,
        createdAt: activityLog.createdAt,
        userName: user.name,
      })
      .from(activityLog)
      .leftJoin(user, eq(activityLog.userId, user.id))
      .orderBy(desc(activityLog.createdAt))
      .limit(15),
  ]);

const stats = [
  {
    label: "หน้าเว็บ",
    count: pageCount,
    icon: "📄",
    color: "#3B82F6",
    href: "/admin/pages",
  },
  {
    label: "สื่อ",
    count: mediaCount,
    icon: "🖼️",
    color: "#8B5CF6",
    href: "/admin/media",
  },
  {
    label: "ผู้ใช้",
    count: userCount,
    icon: "👥",
    color: "#10B981",
    href: "/admin/users",
  },
  {
    label: "ข้อมูลฟอร์ม",
    count: formCount,
    icon: "📋",
    color: "#F59E0B",
    href: "/admin/forms",
  },
];

const actionLabels: Record<string, string> = {
  create: "สร้าง",
  update: "แก้ไข",
  delete: "ลบ",
  publish: "เผยแพร่",
  login: "เข้าสู่ระบบ",
  logout: "ออกจากระบบ",
  upload: "อัปโหลด",
  settings_update: "อัปเดตการตั้งค่า",
  restore: "กู้คืน",
};

const entityLabels: Record<string, string> = {
  page: "หน้า",
  media: "สื่อ",
  user: "ผู้ใช้",
  settings: "การตั้งค่า",
  template: "เทมเพลต",
  form_submission: "ฟอร์ม",
  ab_test: "A/B Test",
};
---

<AdminLayout title="แดชบอร์ด" activeNav="dashboard">
  <!-- Stats Cards -->
  <div class="stats-grid">
    {
      stats.map((s) => (
        <a href={s.href} class="stat-card">
          <div
            class="stat-icon"
            style={`background: ${s.color}15; color: ${s.color}`}
          >
            {s.icon}
          </div>
          <div class="stat-info">
            <span class="stat-count">{s.count}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        </a>
      ))
    }
  </div>

  <!-- Quick Actions -->
  <div class="quick-actions">
    <a href="/admin/pages/new" class="action-btn primary">+ สร้างหน้าใหม่</a>
    <a href="/admin/media" class="action-btn secondary">อัปโหลดสื่อ</a>
  </div>

  <!-- Activity Feed -->
  <div class="activity-section">
    <h2 class="section-title">กิจกรรมล่าสุด</h2>
    <div class="activity-list">
      {
        recentActivity.length === 0 ? (
          <div class="activity-empty">ยังไม่มีกิจกรรม</div>
        ) : (
          recentActivity.map((a) => (
            <div class="activity-item">
              <div class="activity-dot" />
              <div class="activity-content">
                <span class="activity-user">{a.userName ?? "System"}</span>
                <span class="activity-action">
                  {actionLabels[a.action] ?? a.action}
                </span>
                <span class="activity-entity">
                  {entityLabels[a.entityType] ?? a.entityType}
                </span>
                {a.entityId && (
                  <span class="activity-id">#{a.entityId.slice(0, 8)}</span>
                )}
              </div>
              <time class="activity-time">
                {a.createdAt
                  ? new Date(a.createdAt).toLocaleString("th-TH", {
                      month: "short",
                      day: "numeric",
                      hour: "2-digit",
                      minute: "2-digit",
                    })
                  : ""}
              </time>
            </div>
          ))
        )
      }
    </div>
  </div>
</AdminLayout>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .stat-card:hover {
    border-color: #334155;
    transform: translateY(-1px);
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .stat-info {
    display: flex;
    flex-direction: column;
  }

  .stat-count {
    font-size: 1.75rem;
    font-weight: 700;
    color: #f8fafc;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: #94a3b8;
    margin-top: 0.25rem;
  }

  .quick-actions {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .action-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s;
  }

  .action-btn.primary {
    background: #3b82f6;
    color: #fff;
  }

  .action-btn.primary:hover {
    background: #2563eb;
  }

  .action-btn.secondary {
    background: transparent;
    border: 1px solid #334155;
    color: #cbd5e1;
  }

  .action-btn.secondary:hover {
    border-color: #475569;
    color: #f8fafc;
  }

  .section-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #e2e8f0;
    margin-bottom: 1rem;
  }

  .activity-section {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 0.75rem;
    padding: 1.25rem;
  }

  .activity-list {
    display: flex;
    flex-direction: column;
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid #1e293b;
  }

  .activity-item:last-child {
    border-bottom: none;
  }

  .activity-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3b82f6;
    flex-shrink: 0;
  }

  .activity-content {
    flex: 1;
    font-size: 0.8125rem;
    display: flex;
    gap: 0.375rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .activity-user {
    color: #f8fafc;
    font-weight: 500;
  }

  .activity-action {
    color: #94a3b8;
  }

  .activity-entity {
    color: #60a5fa;
  }

  .activity-id {
    color: #64748b;
    font-family: monospace;
    font-size: 0.75rem;
  }

  .activity-time {
    font-size: 0.75rem;
    color: #64748b;
    white-space: nowrap;
  }

  .activity-empty {
    text-align: center;
    color: #64748b;
    padding: 2rem;
    font-size: 0.875rem;
  }
</style>
