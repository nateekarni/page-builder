---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="ข้อมูลฟอร์ม" activeNav="forms">
  <div class="content">
    <div class="header">
      <h1>ข้อมูลฟอร์ม (Form Submissions)</h1>
    </div>

    <div class="placeholder">
      <p>ระบบจัดการฟอร์มกำลังอยู่ในช่วงพัฒนา (Work In Progress)</p>
    </div>
  </div>
</AdminLayout>

<style>
  .content {
    padding: 1rem 0;
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  h1 {
    font-size: 1.5rem;
    color: #f8fafc;
    margin: 0;
  }
  .placeholder {
    background: #1e293b;
    padding: 3rem;
    border-radius: 0.75rem;
    text-align: center;
    color: #94a3b8;
    border: 1px dashed #334155;
  }
</style>
