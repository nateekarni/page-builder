---
import PageEditor from "../../../components/react/editor/PageEditor";
export const prerender = false;

const pageId = Astro.params.id;
---

<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Editor — Aglow</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <PageEditor client:only="react" pageId={pageId} />
  </body>
</html>
