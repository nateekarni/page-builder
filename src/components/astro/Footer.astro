---
/**
 * Footer — Public site footer with social links and copyright.
 *
 * Clean Code: receives all data as props, no data fetching.
 * Semantic HTML: <footer>
 */

interface Props {
  siteName: string;
  tagline?: string;
  socialLinks?: Record<string, unknown>;
}

const { siteName, tagline = '', socialLinks = {} } = Astro.props;
const links = (socialLinks.links ?? []) as { platform: string; url: string }[];
const currentYear = new Date().getFullYear();

const platformLabels: Record<string, string> = {
  facebook: 'Facebook',
  twitter: 'Twitter / X',
  instagram: 'Instagram',
  linkedin: 'LinkedIn',
  youtube: 'YouTube',
  github: 'GitHub',
  tiktok: 'TikTok',
  line: 'LINE',
};
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-container">
    <div class="footer-brand">
      <span class="footer-site-name">{siteName}</span>
      {tagline && <p class="footer-tagline">{tagline}</p>}
    </div>

    {links.length > 0 && (
      <nav class="footer-social" aria-label="Social links">
        <ul class="social-list">
          {links.map((link) => (
            <li>
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
                aria-label={platformLabels[link.platform] ?? link.platform}
              >
                {platformLabels[link.platform] ?? link.platform}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <p class="footer-copyright">
      &copy; {currentYear} {siteName}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-foreground);
    color: var(--color-background);
    padding: var(--section-padding) 1.5rem 2rem;
    margin-top: auto;
  }

  .footer-container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    text-align: center;
  }

  .footer-site-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .footer-tagline {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .social-list {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }

  .social-link {
    color: var(--color-background);
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .social-link:hover {
    opacity: 1;
  }

  .footer-copyright {
    font-size: 0.8125rem;
    opacity: 0.5;
    margin-top: 1.5rem;
  }
</style>
